{
  "name": "ngx-admin",
  "version": "11.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akveo/ngx-admin.git"
  },
  "bugs": {
    "url": "https://github.com/akveo/ngx-admin/issues"
  },
  "scripts": {
    "ng": "ng",
    "conventional-changelog": "conventional-changelog",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "npm run build -- --configuration production --aot",
    "test": "ng test",
    "test:coverage": "rimraf coverage && npm run test -- --code-coverage",
    "lint": "ng lint",
    "lint:fix": "ng lint ngx-admin-demo --fix",
    "lint:styles": "stylelint ./src/**/*.scss",
    "lint:ci": "npm run lint && npm run lint:styles",
    "docs": "compodoc -p src/tsconfig.app.json -d docs",
    "docs:serve": "compodoc -p src/tsconfig.app.json -d docs -s",
    "prepush": "npm run lint:ci",
    "release:changelog": "npm run conventional-changelog -- -p angular -i CHANGELOG.md -s",
    "postinstall": "node scripts/patch-cdk.js",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "audit:high": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/google-maps": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@bluehalo/ngx-leaflet": "^21.0.0",
    "@nebular/auth": "^17.0.0",
    "@nebular/eva-icons": "^17.0.0",
    "@nebular/security": "^17.0.0",
    "@nebular/theme": "^17.0.0",
    "@swimlane/ngx-charts": "^20.5.0",
    "angular2-smart-table": "^4.1.1",
    "bootstrap": "^5.3.0",
    "chart.js": "^4.4.0",
    "echarts": "^5.4.0",
    "eva-icons": "^1.1.3",
    "ionicons": "2.0.1",
    "leaflet": "^1.9.4",
    "lodash-es": "^4.17.21",
    "nebular-icons": "1.1.0",
    "ng2-completer": "^9.0.1",
    "ngx-echarts": "^21.0.0",
    "normalize.css": "6.0.0",
    "pace-js": "1.0.2",
    "roboto-fontface": "0.8.0",
    "rxjs": "^7.8.1",
    "socicon": "3.0.5",
    "style-loader": "^1.3.0",
    "tinymce": "^7.0.0",
    "tslib": "^2.3.1",
    "typeface-exo": "0.0.22",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular-eslint/builder": "^21.0.0",
    "@angular-eslint/eslint-plugin": "^21.0.0",
    "@angular-eslint/eslint-plugin-template": "^21.0.0",
    "@angular-eslint/schematics": "^21.0.0",
    "@angular-eslint/template-parser": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/language-service": "^21.0.0",
    "@compodoc/compodoc": "1.0.1",
    "@fortawesome/fontawesome-free": "^5.2.0",
    "@stylistic/stylelint-plugin": "^5.0.1",
    "@types/d3-color": "1.0.5",
    "@types/jasmine": "~5.1.0",
    "@types/leaflet": "^1.9.8",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "conventional-changelog-cli": "1.3.4",
    "eslint": "^8.28.0",
    "husky": "0.13.3",
    "jasmine-core": "~5.5.0",
    "jsdom": "^25.0.0",
    "npm-run-all": "4.0.2",
    "postcss-scss": "^4.0.9",
    "rimraf": "2.6.1",
    "sass": "^1.69.0",
    "stylelint": "^16.0.0",
    "ts-node": "3.2.2",
    "typescript": "~5.9.0",
    "vitest": "^4.0.0"
  }
}
